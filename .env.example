# ===========================================
# Frigate-Gotify Configuration
# ===========================================
# Copy this file to .env and configure your settings

# ===========================================
# Frigate NVR Configuration
# ===========================================
# URL of your Frigate NVR server
FRIGATE_URL=http://frigate:5000

# Authentication (use one of the following methods)
# Option 1: API Key (if configured in Frigate)
# FRIGATE_API_KEY=your_api_key

# Option 2: Username/Password (basic auth)
# FRIGATE_USERNAME=admin
# FRIGATE_PASSWORD=password

# ===========================================
# Gotify Configuration
# ===========================================
# URL of your Gotify server
GOTIFY_URL=https://gotify.example.com

# Application token from Gotify (create an app in Gotify to get this)
GOTIFY_APP_TOKEN=your_gotify_app_token_here

# ===========================================
# SSL Configuration
# ===========================================
# Set to false if using self-signed certificates or local HTTP
VERIFY_SSL=false

# ===========================================
# Polling Configuration
# ===========================================
# Interval in seconds between polling for new review events
POLL_INTERVAL=10

# ===========================================
# Notification Configuration
# ===========================================
# Default priority for Gotify notifications (0-10)
# 0 = min priority, 10 = max priority
NOTIFICATION_PRIORITY=5

# Include snapshot images in notifications
INCLUDE_SNAPSHOT=true

# ===========================================
# Image Configuration
# ===========================================
# Snapshot quality (1-100, higher = better quality but larger size)
SNAPSHOT_QUALITY=90

# Snapshot format (jpg, png, webp)
# jpg = best compression, png = lossless, webp = modern format
SNAPSHOT_FORMAT=jpg

# ===========================================
# Filter Configuration
# ===========================================
# Comma-separated list of severity levels to notify on
# Options: alert, detection, significant
SEVERITY_FILTER=alert,detection

# Comma-separated list of cameras to monitor, or 'all'
CAMERA_FILTER=all

# ===========================================
# Template Configuration (Jinja2)
# ===========================================
# Available variables for all templates:
#   {{camera}}          - Camera ID (e.g., "front_door")
#   {{camera_name}}     - Camera name formatted (e.g., "Front Door")
#   {{object}}          - Detected object label (e.g., "person", "car")
#   {{object_label}}    - Same as {{object}}
#   {{sub_label}}       - Sub-label if available (e.g., "license_plate", "UPS")
#   {{sublabel}}        - Alias for sub_label
#   {{location}}        - Location/zone name
#   {{zone}}            - Alias for location
#   {{zones}}           - List of all zones
#   {{severity}}        - Event severity (alert, detection)
#   {{genai_description}} - GenAI description from Frigate
#   {{genai}}           - Alias for genai_description
#   {{ai_summary}}      - Alias for genai_description
#   {{audio}}           - List of detected audio
#   {{audio_detected}}  - Comma-separated audio detections
#   {{timestamp}}       - Event timestamp
#   {{time}}            - Alias for timestamp
#   {{score}}           - Detection confidence score (0-1)
#   {{confidence}}      - Formatted confidence (e.g., "85%")
#   {{object_display}}  - Formatted object with sub-label

# Default title template
# TITLE_TEMPLATE=[{{ severity|upper }}] {{ camera }}

# Default message template
# MESSAGE_TEMPLATE={{ camera }} detected {{ object }}{% if sub_label %} ({{ sub_label }}){% endif %} in {{ location }}.{% if genai_description %}\n\n**AI Summary:** {{ genai_description }}{% endif %}

# Object-specific templates (format: object:template;object2:template2)
# These override the default template for specific objects
# Example:
# OBJECT_TEMPLATES=person:{{ camera }} detected a person in {{ location }}.{% if genai_description %}\n\n{{ genai_description }}{% endif %};car:{{ camera }} detected a vehicle{% if sub_label %} ({{ sub_label }}){% endif %} in {{ location }}.

# Severity-specific templates (format: severity:template;severity2:template2)
# Example:
# SEVERITY_TEMPLATES=alert:🚨 ALERT: {{ camera }} detected {{ object }} in {{ location }}!;detection:{{ camera }}: {{ object }} detected in {{ location }}.

# Camera-specific templates (format: camera:template;camera2:template2)
# Example:
# CAMERA_TEMPLATES=front_door:🚪 Front Door: {{ object }} detected{% if sub_label %} ({{ sub_label }}){% endif %};backyard:🌳 Backyard: {{ object }} detected

# ===========================================
# Example Template Configurations
# ===========================================

# Example 1: Simple format
# TITLE_TEMPLATE={{ camera_name }} - {{ object }}
# MESSAGE_TEMPLATE={{ camera }} detected {{ object_display }} in {{ location }}.{% if genai_description %}\n\n{{ genai_description }}{% endif %}

# Example 2: Detailed with all info
# TITLE_TEMPLATE=[{{ severity|upper }}] {{ camera_name }}
# MESSAGE_TEMPLATE=Detected: {{ object_display }}\nLocation: {{ location }}\nTime: {{ timestamp }}{% if genai_description %}\n\n**AI Analysis:** {{ genai_description }}{% endif %}{% if audio_detected %}\n\n**Audio:** {{ audio_detected }}{% endif %}

# Example 3: Minimal
# TITLE_TEMPLATE={{ object|title }} detected
# MESSAGE_TEMPLATE={% if genai_description %}{{ genai_description }}{% else %}{{ object }} in {{ location }}{% endif %}

# Example 4: Mail carrier special template
# OBJECT_TEMPLATES=person:{{ camera }} detected someone{% if sub_label %} (appears to be {{ sub_label }}){% endif %} in {{ location }}.{% if genai_description %}\n\n{{ genai_description }}{% endif %}

# ===========================================
# Debug Configuration
# ===========================================
# Enable debug logging
DEBUG=false