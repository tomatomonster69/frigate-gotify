# =============================================================================
# Frigate-Gotify Configuration
# Copy this file to .env and adjust values for your setup
# =============================================================================

# -----------------------------------------------------------------------------
# FRIGATE NVR CONFIGURATION
# -----------------------------------------------------------------------------
# URL of your Frigate NVR server (use HTTP to avoid SSL issues on local network)
FRIGATE_URL=http://frigate:5000

# Frigate authentication (optional - only needed if auth is enabled)
# FRIGATE_USERNAME=admin
# FRIGATE_PASSWORD=password
# FRIGATE_API_KEY=your_api_key

# -----------------------------------------------------------------------------
# GOTIFY CONFIGURATION
# -----------------------------------------------------------------------------
# URL of your Gotify server
GOTIFY_URL=http://gotify-server:80

# Application token from Gotify (required)
# Create an application in Gotify UI and copy the token here
GOTIFY_APP_TOKEN=your_gotify_app_token_here

# -----------------------------------------------------------------------------
# SSL CONFIGURATION
# -----------------------------------------------------------------------------
# Set to false for local HTTP connections (recommended for local network)
VERIFY_SSL=false

# -----------------------------------------------------------------------------
# POLLING CONFIGURATION
# -----------------------------------------------------------------------------
# Interval in seconds between polling for new review events
POLL_INTERVAL=10

# -----------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Default priority for notifications (1-10, higher = more important)
NOTIFICATION_PRIORITY=5

# Include snapshot images in notifications (recommended)
INCLUDE_SNAPSHOT=true

# -----------------------------------------------------------------------------
# FILTER CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of severity levels to notify on
# Options: alert, detection
SEVERITY_FILTER=alert,detection

# Comma-separated list of cameras to monitor, or 'all' for all cameras
CAMERA_FILTER=all

# -----------------------------------------------------------------------------
# DEBUG CONFIGURATION
# -----------------------------------------------------------------------------
# Enable debug logging (set to true for troubleshooting)
DEBUG=false